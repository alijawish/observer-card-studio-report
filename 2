// ── Canvas text wrap ─────────────────────────────────────────────────────────
function wrapText(ctx, text, x, y, maxW, lh) {
  const words = text.split(" ");
  let line = "", cy = y;
  for (let n = 0; n < words.length; n++) {
    const test = line + words[n] + " ";
    if (ctx.measureText(test).width > maxW && n > 0) {
      ctx.fillText(line.trim(), x, cy);
      line = words[n] + " ";
      cy += lh;
    } else { line = test; }
  }
  ctx.fillText(line.trim(), x, cy);
}

