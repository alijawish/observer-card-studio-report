                <div style={{color:pal.accent,fontSize:10,letterSpacing:"0.1em",marginTop:2}}>
                  OMAN OBSERVER PODCAST
                </div>
              </div>
            </div>
          ) : form.logoStyle==="emblem" ? (
            <div style={{width:100,height:100,borderRadius:"50%",
              border:`2px solid ${pal.accent}`,display:"flex",
              alignItems:"center",justifyContent:"center",flexDirection:"column",gap:3}}>
              <div style={{color:pal.accent,fontSize:9,letterSpacing:"0.12em"}}>OO PODCAST</div>
              <div style={{color:pal.text,fontSize:11,fontWeight:700,
                fontFamily:form.font.stack,textAlign:"center",maxWidth:72}}>
                {(form.showName||"Show Name").slice(0,10)}
              </div>
            </div>
          ) : (
            <div style={{textAlign:"center"}}>
              <div style={{color:pal.text,fontSize:26,fontWeight:700,
                fontFamily:form.font.stack,letterSpacing:"0.03em"}}>
                {form.showName||"Your Show Name"}
              </div>
              <div style={{color:pal.accent,fontSize:10,letterSpacing:"0.14em",marginTop:5}}>
                AN OMAN OBSERVER PODCAST
              </div>
            </div>
          )}
        </div>
        {/* White reversed */}
        <div style={{background:"#f4f4f4",borderRadius:7,padding:"16px 20px",
          display:"flex",alignItems:"center",justifyContent:"center",minHeight:60}}>
          <div style={{color:pal.bg,fontSize:20,fontWeight:700,fontFamily:form.font.stack}}>
            {form.showName||"Show Name"}
          </div>
        </div>
        <div style={{fontSize:11,color:"#444",marginTop:8}}>↑ Dark version + white-background reversed</div>
      </div>

      <button style={S.primary} onClick={genLogoSpec} disabled={loading}>
        {loading?"⏳ Generating...":"✦ Generate Full Logo Specification"}
      </button>

      {aiOut && (
        <div style={{...S.card,marginTop:14,maxHeight:420,overflowY:"auto"}}>
          <pre style={{color:"#bbb",fontSize:13,lineHeight:1.75,whiteSpace:"pre-wrap",
            fontFamily:"inherit",margin:0}}>{aiOut}</pre>
        </div>
      )}
    </div>
  );

  const Step3 = () => (
    <div>
      <h3 style={S.h}>Main Podcast Cover</h3>
      <div style={{...S.card,padding:0,overflow:"hidden"}}>
        <canvas ref={mainCv} style={{width:"100%",display:"block"}}/>
      </div>

      <div style={{...S.card,background:"#080808"}}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,
          letterSpacing:"0.07em",marginBottom:12}}>TECHNICAL SPECS</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:0}}>
          {[["Dimensions","3000 × 3000 px"],["Resolution","72 DPI, RGB"],
            ["Max filesize","500 KB"],["Format","JPEG or PNG"],
            ["Aspect ratio","1:1 Square"],["Safe zone","Keep bottom 15% clear"]
          ].map(([k,v])=>(
            <div key={k} style={{display:"flex",justifyContent:"space-between",
              padding:"7px 0",borderBottom:"1px solid #181818",fontSize:12}}>
              <span style={{color:"#555"}}>{k}</span>
              <span style={{color:pal.text,fontWeight:600}}>{v}</span>
            </div>
          ))}
        </div>
        <div style={{marginTop:14,padding:"10px 12px",background:pal.accent+"12",
          borderRadius:6,fontSize:12,color:pal.accent,borderLeft:`3px solid ${pal.accent}`}}>
          ⚠ Apple Podcasts overlays a progress bar on the bottom 15%. Keep logo and show
          name well above that threshold.
        </div>
      </div>

      <button style={S.primary} onClick={genBrandGuide} disabled={loading}>
        {loading?"⏳ Generating...":"✦ Generate Full Brand Identity Guide"}
      </button>

      {aiOut && (
        <div style={{...S.card,marginTop:14,maxHeight:500,overflowY:"auto"}}>
          <pre style={{color:"#bbb",fontSize:13,lineHeight:1.8,whiteSpace:"pre-wrap",
            fontFamily:"inherit",margin:0}}>{aiOut}</pre>
        </div>
      )}
    </div>
  );

  const Step4 = () => (
    <div>
      <h3 style={S.h}>Episode Cover — Guest Edition</h3>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
        {[
          ["guestName","Guest Full Name","e.g. Dr. Hessa Al-Lawati"],
          ["guestRole","Title / Role","e.g. CEO, Oman Investment Authority"],
          ["guestOrg","Organisation","e.g. Oman Investment Authority"],
          ["episodeTitle","Episode Title","e.g. Building Oman's Sovereign Wealth"],
          ["episodeNumber","Episode Number","e.g. 7"],
        ].map(([k,lbl,ph])=>(
          <div key={k} style={S.field}>
            <label style={S.label}>{lbl}</label>
            <input style={S.input} value={form[k]} onChange={e=>up(k,e.target.value)} placeholder={ph}/>
          </div>
        ))}
      </div>

      <div style={{...S.card,padding:0,overflow:"hidden",marginTop:4}}>
        <canvas ref={episodeCv} style={{width:"100%",display:"block"}}/>
      </div>

      <div style={{...S.card,background:"#080808",marginTop:14}}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,letterSpacing:"0.07em",marginBottom:10}}>
          EPISODE COVER RULES
        </div>
        {[
          "Show name visible, secondary to the episode identity",
          "Guest name is the largest typographic element",
          "Episode number in a consistent badge position (top-right)",
          "'Oman Observer Podcast' credited — present, not dominant",
          "Legible at 150×150 px thumbnail",
          "Guest face area minimum 300 px (photo or AI-generated stand-in)",
        ].map(item=>(
          <div key={item} style={{display:"flex",gap:10,padding:"5px 0",
            borderBottom:"1px solid #141414",fontSize:12,color:"#777"}}>
            <span style={{color:pal.accent}}>✓</span>{item}
          </div>
        ))}
      </div>

      <button style={S.primary} onClick={genSocialPack} disabled={loading}>
        {loading?"⏳ Generating...":"✦ Generate Full Social Media Pack"}
      </button>

      {aiOut && (
        <div style={{...S.card,marginTop:14,maxHeight:500,overflowY:"auto"}}>
          <pre style={{color:"#bbb",fontSize:13,lineHeight:1.8,whiteSpace:"pre-wrap",
            fontFamily:"inherit",margin:0}}>{aiOut}</pre>
        </div>
      )}
    </div>
  );

  const Step5 = () => (
    <div>
      <h3 style={S.h}>✦ Brand Summary</h3>

      {/* Identity card */}
      <div style={S.card}>
        <div style={{display:"flex",gap:16,alignItems:"flex-start",marginBottom:20}}>
          <div style={{flexShrink:0}}>
            <div style={{width:52,height:52,borderRadius:9,background:pal.accent,
              display:"flex",alignItems:"center",justifyContent:"center",
              fontSize:13,fontWeight:900,color:pal.bg}}>OO</div>
            <div style={{width:52,height:2,background:pal.accent+"38",margin:"4px 0"}}/>
            <div style={{width:52,height:30,borderRadius:6,
              border:`1px solid ${pal.accent}44`,
              display:"flex",alignItems:"center",justifyContent:"center",
              fontSize:9,fontWeight:700,color:pal.accent,textAlign:"center"}}>
              {(form.showName||"SHOW").slice(0,6).toUpperCase()}
            </div>
          </div>
          <div>
            <div style={{color:"#444",fontSize:11,letterSpacing:"0.08em",marginBottom:4}}>
              OMAN OBSERVER PODCAST
            </div>
            <div style={{color:pal.text,fontSize:22,fontWeight:700,fontFamily:form.font.stack}}>
              {form.showName||"Your Show"}
            </div>
            {form.tagline&&<div style={{color:pal.accent,fontSize:13,marginTop:4,fontStyle:"italic"}}>
              "{form.tagline}"</div>}
            {form.hostName&&<div style={{color:"#555",fontSize:12,marginTop:4}}>
              Hosted by {form.hostName}</div>}
          </div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
          {[
            ["Palette",   pal.name],
            ["Font",      form.font.name],
            ["Logo",      LOGO_STYLES.find(l=>l.id===form.logoStyle)?.label||"—"],
            ["Category",  form.category||"—"],
            ["Cover",     LAYOUT_STYLES.find(l=>l.id===form.coverLayout)?.label||"—"],
            ["Language",  "English"],
          ].map(([label,value])=>(
            <div key={label} style={{background:"#0a0a0a",borderRadius:7,padding:11}}>
              <div style={{fontSize:10,color:"#444",letterSpacing:"0.07em",marginBottom:3}}>
                {label.toUpperCase()}</div>
              <div style={{fontSize:12,color:pal.text,fontWeight:600}}>{value}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Colour swatches */}
      <div style={S.card}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,
          letterSpacing:"0.07em",marginBottom:12}}>OFFICIAL COLOUR PALETTE</div>
        <div style={{display:"flex",gap:10}}>
          {[["Background",pal.bg],["Accent",pal.accent],["Text",pal.text],["Secondary",pal.secondary]
          ].map(([label,color])=>(
            <div key={label} style={{flex:1,textAlign:"center"}}>
              <div style={{height:48,borderRadius:7,background:color,
                border:"1px solid #ffffff10",marginBottom:6}}/>
              <div style={{fontSize:11,color:"#555"}}>{label}</div>
              <div style={{fontSize:10,color:"#444",fontFamily:"monospace",marginTop:1}}>{color}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Deliverables */}
      <div style={S.card}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,
          letterSpacing:"0.07em",marginBottom:12}}>DELIVERABLES CHECKLIST</div>
        {[
          ["Logo SVG package","All 6 versions: colour, reversed, mono white/black, favicon, co-branded lockup",true],
          ["Main cover art","3000×3000 px JPEG < 500 KB — submit to Apple & Spotify",true],
          ["Episode cover template","Figma / PSD with locked zones for show, guest, episode info",true],
          ["Social media pack","Instagram, Story, YouTube thumbnail, Twitter/X, LinkedIn, Audiogram",true],
          ["Brand Guidelines PDF","All rules, colour codes, fonts, co-branding with Oman Observer",true],
          ["Font licence files","Cleared fonts for team use in Figma / Adobe apps",false],
          ["Audio branding brief","Intro jingle tone and outro music direction",false],
        ].map(([title,desc,done])=>(
          <div key={title} style={{display:"flex",gap:12,padding:"9px 0",
            borderBottom:"1px solid #141414",alignItems:"flex-start"}}>
            <div style={{width:18,height:18,borderRadius:4,flexShrink:0,marginTop:1,
              background:done?pal.accent+"22":"#1a1a1a",
              border:`1px solid ${done?pal.accent:"#2a2a2a"}`,
              display:"flex",alignItems:"center",justifyContent:"center"}}>
              {done&&<span style={{color:pal.accent,fontSize:11}}>✓</span>}
            </div>
            <div>
              <div style={{color:pal.text,fontSize:13,fontWeight:600}}>{title}</div>
              <div style={{color:"#555",fontSize:11,marginTop:2}}>{desc}</div>
            </div>
          </div>
        ))}
      </div>

      {/* Co-branding hierarchy */}
      <div style={{...S.card,borderColor:pal.accent+"44",background:"#08080f"}}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,
          letterSpacing:"0.07em",marginBottom:12}}>CO-BRANDING HIERARCHY</div>
        <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:12}}>
          <div style={{flex:1,background:"#0e0e0e",borderRadius:7,padding:12,
            textAlign:"center",border:`1px solid ${pal.accent}30`}}>
            <div style={{color:pal.accent,fontSize:11,fontWeight:700}}>Oman Observer</div>
            <div style={{color:"#444",fontSize:10,marginTop:2}}>
              Parent brand — always present, never dominant
            </div>
          </div>
          <div style={{color:"#333",fontSize:20}}>›</div>
          <div style={{flex:1,background:"#0e0e0e",borderRadius:7,padding:12,
            textAlign:"center",border:`1px solid ${pal.accent}50`}}>
            <div style={{color:pal.text,fontSize:13,fontWeight:700,fontFamily:form.font.stack}}>
              {form.showName||"Your Show"}
            </div>
            <div style={{color:"#555",fontSize:10,marginTop:2}}>
              Sub-show — primary identity on all episode art
            </div>
          </div>
        </div>
        <div style={{fontSize:12,color:"#444",lineHeight:1.65}}>
          The sub-show name is the hero on episode covers and social posts.
          "Oman Observer Podcast" appears as a secondary attribution line —
          always present for credibility and discoverability, never competing for visual dominance.
        </div>
      </div>

      {/* Reference shows */}
      <div style={{...S.card,background:"#070707"}}>
        <div style={{fontSize:11,color:pal.accent,fontWeight:700,
          letterSpacing:"0.07em",marginBottom:10}}>
          REFERENCE: STRONG PODCAST VISUAL IDENTITIES
        </div>
        {[
          ["The Daily (NYT)","Stripped-back wordmark — parent-brand trust transfers instantly"],
          ["Hard Fork (NYT)","Bold two-tone split — sub-brand carved its own personality"],
          ["Intelligence Squared","Editorial typography — authority without heavy-handedness"],
          ["Freakonomics Radio","Illustrative icon — memorable across a decade of covers"],
          ["The Ezra Klein Show","Host-name wordmark — personality as the brand anchor"],
          ["Serial","Sparse type only — mystery as a deliberate design choice"],
        ].map(([name,desc])=>(
          <div key={name} style={{display:"flex",justifyContent:"space-between",
            alignItems:"flex-start",padding:"7px 0",
            borderBottom:"1px solid #131313",fontSize:12}}>
            <span style={{color:pal.text,fontWeight:600,minWidth:180}}>{name}</span>
            <span style={{color:"#444",textAlign:"right",flex:1}}>{desc}</span>
          </div>
        ))}
      </div>
    </div>
  );

  const views = [Step0, Step1, Step2, Step3, Step4, Step5];
  const Current = views[step];

  // ── Shell ────────────────────────────────────────────────────────────────
  return (
    <div style={{fontFamily:"'Segoe UI',system-ui,sans-serif",background:"#080808",
      minHeight:"100vh",color:"#f0f0f0"}}>

      {/* Header */}
      <div style={{background:"#0a0a0a",borderBottom:`1px solid ${pal.accent}18`,
        padding:"14px 24px",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
        <div>
          <div style={{fontSize:15,fontWeight:700,color:pal.text,letterSpacing:"0.02em"}}>
            Podcast Identity Designer
          </div>
          <div style={{fontSize:10,color:pal.accent,marginTop:2,letterSpacing:"0.1em"}}>
            OMAN OBSERVER — ENGLISH SUB-SHOW BRAND SYSTEM
          </div>
        </div>
        <div style={{display:"flex",gap:5}}>
          {[pal.bg,pal.accent,pal.text].map((c,i)=>(
            <div key={i} style={{width:11,height:11,borderRadius:"50%",
              background:c,border:"1px solid #ffffff12"}}/>
          ))}
        </div>
      </div>

      {/* Step tabs */}
      <div style={{background:"#0a0a0a",borderBottom:`1px solid ${pal.accent}0C`,
        padding:"0 24px",display:"flex",overflowX:"auto"}}>
        {STEPS.map((s,i)=>(
          <button key={s} onClick={()=>{setStep(i);setAiOut("");}}
            style={{background:"none",border:"none",cursor:"pointer",
              padding:"11px 15px",fontSize:12,whiteSpace:"nowrap",fontFamily:"inherit",
              transition:"all .15s",
              color:step===i?pal.accent:"#3a3a3a",
              fontWeight:step===i?700:400,
              borderBottom:step===i?`2px solid ${pal.accent}`:"2px solid transparent"}}>
            {i+1}. {s}
          </button>
        ))}
      </div>

      {/* Content */}
      <div style={{maxWidth:720,margin:"0 auto",padding:"24px 24px 48px"}}>
        <Current/>

        {/* Nav */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",
          marginTop:28,paddingTop:18,borderTop:`1px solid ${pal.accent}15`}}>
          {step>0
            ?<button style={S.ghost} onClick={()=>{setStep(s=>s-1);setAiOut("");}}>← Back</button>
            :<div/>}
          {step<STEPS.length-1&&
            <button style={S.primary} onClick={()=>{setStep(s=>s+1);setAiOut("");}}>
              Next →
            </button>}
        </div>
      </div>
    </div>
  );
}
